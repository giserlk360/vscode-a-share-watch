{
  "name": "vscode-a-share-watch",
  "displayName": "A股盯盘",
  "description": "在 VS Code 侧边栏查看 A 股行情，支持自选股、持有股、预购股、持仓盈亏和走势查看",
  "version": "0.0.2",
  "publisher": "giserlk360",
  "icon": "resources/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/giserlk360/vscode-a-share-watch"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "stock",
    "A股",
    "股票",
    "行情",
    "监控",
    "持仓",
    "自选股",
    "侧边栏",
    "看板"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "stock-monitor",
          "title": "A股盯盘",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "stock-monitor": [
        {
          "id": "stockMonitor.stockView",
          "name": "股票列表",
          "type": "webview"
        },
        {
          "id": "settingsView",
          "name": "插件设置",
          "type": "webview"
        }
      ]
    },
    "commands": [
      {
        "command": "vscode-stock-monitor.addStock",
        "title": "添加股票",
        "icon": "$(add)"
      },
      {
        "command": "vscode-stock-monitor.editStock",
        "title": "编辑股票",
        "icon": "$(edit)"
      },
      {
        "command": "vscode-stock-monitor.deleteStock",
        "title": "删除股票",
        "icon": "$(trash)"
      },
      {
        "command": "vscode-stock-monitor.refreshStocks",
        "title": "刷新股票数据",
        "icon": "$(refresh)"
      },
      {
        "command": "vscode-stock-monitor.openSettings",
        "title": "打开设置"
      },
      {
        "command": "stock-monitor.addStock",
        "title": "添加股票",
        "icon": "$(add)"
      },
      {
        "command": "stock-monitor.editStock",
        "title": "编辑股票",
        "icon": "$(edit)"
      },
      {
        "command": "stock-monitor.deleteStock",
        "title": "删除股票",
        "icon": "$(trash)"
      },
      {
        "command": "stock-monitor.refreshView",
        "title": "刷新视图",
        "icon": "$(refresh)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "stock-monitor.refreshView",
          "when": "view == stockMonitor.stockView",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "A股盯盘",
      "properties": {
        "vscode-stock-monitor.refreshInterval": {
          "type": "number",
          "default": 10,
          "description": "股票数据刷新间隔（秒）"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "node build.js --production",
    "build": "node build.js",
    "watch": "node build.js --watch",
    "test": "node ./out/test/runTest.js",
    "test:unit": "npx jest --testPathPattern=src/test/unit",
    "test:property": "npx jest --testPathPattern=src/test/property",
    "lint": "eslint src --ext ts",
    "compile": "tsc -p ./"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^18.19.130",
    "@types/vscode": "^1.80.0",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.19.12",
    "fast-check": "^3.23.2",
    "jest": "^29.7.0",
    "ts-jest": "^29.4.9",
    "typescript": "^5.9.3"
  }
}
